#!/usr/bin/env python

import os
import sys
import json
import jmespath
import requests
import argparse

ANILIST_COMICINFO_JMESMAP = {
    'Series': 'title.romaji',
    'LocalizedSeries': 'title.english',
    'Count': 'volumes',
    'Writer': 'staff.edges[?role.contains(@, `Story`)].node.name.full | [0]',
    'Penciller': 'staff.edges[?role.contains(@, `Art`)].node.name.full | [0]',
    'Inker': 'staff.edges[?role.contains(@, `Art`)].node.name.full | [0]',
    'Colorist': 'staff.edges[?role.contains(@, `Art`)].node.name.full | [0]',
    'Publisher': 'studios.edges[?isMain==true].node.name | [0]',
    'Genre': 'genres[*] | join(`,`, @)',
    'Tags': 'tags[*].name | join(`,`, @)',
    'Summary': 'description',
    'Web': 'siteUrl',
    'Year': 'startDate.year',
    'Month': 'startDate.month',
    'Day': 'startDate.day',
}

def get_series_info_by_id(series_id):
    url = 'https://graphql.anilist.co'
    media_format = 'MANGA'
    query = '''
            query search_details_by_series_id ($series_id: Int, $format: MediaFormat) {
              Media (id: $series_id, type: MANGA, format: $format) {
                id
                volumes
                siteUrl
                title {
                  romaji
                  english
                }
                studios {
                  edges {
                    node {
                      name
                    }
                  }
                }
                staff {
                  edges {
                    role
                    node {
                      name {
                        full
                      }
                    }
                  }
                }
                genres
                tags {
                  name
                }
                description
                startDate {
                  day
                  month
                  year
                }
              }
            }
            '''
    variables = {
        'series_id': series_id,
        'format': media_format
    }
    response = requests.post(url, json={'query': query, 'variables': variables})
    return response.json()

def map(anilist_data):
    data = {}

    if not anilist_data:
        return data

    for comicinfo_key, anilist_key in ANILIST_COMICINFO_JMESMAP.items():
        data[comicinfo_key] = jmespath.search(anilist_key, anilist_data)

    return data

def cbtag(series_id, dryrun):
    data = get_series_info_by_id(series_id).get('data', {}).get('Media', {})
    print(json.dumps(map(data), indent=2))

def main():
    parser = argparse.ArgumentParser(prog='cbtag')
    parser.add_argument('--series-id', type=int, default=33614)
    parser.add_argument('--dryrun', action='store_true')
    args = parser.parse_args()

    try:
        cbtag(**vars(args))
    except KeyboardInterrupt:
        return 1

    return 0

if __name__ == '__main__':
    sys.exit(main())
