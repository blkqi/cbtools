#!/usr/bin/env python

import os
import sys
import json
import pathlib
import tempfile
import jmespath
import requests
import argparse
import dictdiffer

from cbtools import CBZFile, ComicInfo

ANILIST_COMICINFO_JMESMAP = {
    'Series': 'title.romaji',
    'LocalizedSeries': 'title.english',
    'Count': 'volumes',
    'Writer': 'staff.edges[?role.contains(@, `Story`)].node.name.full | [0]',
    'Penciller': 'staff.edges[?role.contains(@, `Art`)].node.name.full | [0]',
    'Inker': 'staff.edges[?role.contains(@, `Art`)].node.name.full | [0]',
    'Colorist': 'staff.edges[?role.contains(@, `Art`)].node.name.full | [0]',
    'Publisher': 'studios.edges[?isMain==true].node.name | [0]',
    'Genre': 'genres[*] | join(`,`, @)',
    'Tags': 'tags[*].name | join(`,`, @)',
    'Summary': 'description',
    'Web': 'siteUrl',
    'Year': 'startDate.year',
    'Month': 'startDate.month',
    'Day': 'startDate.day',
}

def get_series_info_by_id(series_id):
    url = 'https://graphql.anilist.co'
    media_format = 'MANGA'
    query = '''
            query search_details_by_series_id ($series_id: Int, $format: MediaFormat) {
              Media (id: $series_id, type: MANGA, format: $format) {
                id
                volumes
                siteUrl
                title {
                  romaji
                  english
                }
                studios {
                  edges {
                    node {
                      name
                    }
                  }
                }
                staff {
                  edges {
                    role
                    node {
                      name {
                        full
                      }
                    }
                  }
                }
                genres
                tags {
                  name
                }
                description
                startDate {
                  day
                  month
                  year
                }
              }
            }
            '''
    variables = {
        'series_id': series_id,
        'format': media_format
    }
    response = requests.post(url, json={'query': query, 'variables': variables})
    return response.json()

def map_result(anilist_data):
    cinfo = ComicInfo()

    if not anilist_data:
        return cinfo

    for comicinfo_key, anilist_key in ANILIST_COMICINFO_JMESMAP.items():
        value = jmespath.search(anilist_key, anilist_data)
        if value:
            cinfo[comicinfo_key] = str(value)

    return cinfo

def print_cinfo_diff(left, right):
    result = dictdiffer.diff(left, right)
    for item in result:
        print(item)

def replace_cfile_cinfo(cfile_path, cinfo_path):
    # create temp space for extraction
    with tempfile.TemporaryDirectory() as extract_dir:
        extract_path = pathlib.Path(extract_dir)

        # extract original archive
        with CBZFile(cfile_path, mode='r') as cfile:
            cfile.extractall(path=extract_path, flatten=True)

        # remove previous ComicInfo.xml, if it exists
        (extract_path / ComicInfo.XML_FILENAME).unlink(missing_ok=True)

        # write new archive with new ComicInfo.xml
        cfile_temp_path = cfile_path.with_suffix('.cbz.tmp')

        with CBZFile(cfile_temp_path, mode='w') as cfile_temp:
            cfile_temp.write(cinfo_path, arcname=ComicInfo.XML_FILENAME)

            for path in sorted(extract_path.iterdir()):
                cfile_temp.write(path, arcname=path.name)

        # replace original archive
        cfile_temp_path.rename(cfile_path)

def cbtag(files, series_id, dryrun):
    cinfo = map_result(get_series_info_by_id(series_id).get('data', {}).get('Media', {}))

    if dryrun:
        for path in files:
            with CBZFile(path) as cfile:
                print_cinfo_diff(cfile.info(), cinfo)
    else:
        with tempfile.TemporaryDirectory() as cinfo_dir:
            # write new ComicInfo.xml
            cinfo_path = pathlib.Path(cinfo_dir) / ComicInfo.XML_FILENAME
            cinfo_path.write_bytes(cinfo.encode())

            for path in files:
                replace_cfile_cinfo(path, cinfo_path)

def main():
    parser = argparse.ArgumentParser(prog='cbtag')
    parser.add_argument('files', nargs='*', type=pathlib.Path)
    parser.add_argument('--series-id', type=int, default=33614)
    parser.add_argument('--dryrun', action='store_true')
    args = parser.parse_args()

    try:
        cbtag(**vars(args))
    except KeyboardInterrupt:
        return 1

    return 0

if __name__ == '__main__':
    sys.exit(main())
