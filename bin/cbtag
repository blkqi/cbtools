#!/usr/bin/env python

import sys
import pathlib
import argparse
import logging

from cbtools.tag import AniList, cbtag

PROG_NAME = 'cbtag'
logger = logging.getLogger(PROG_NAME)

def cbtag(files, series_id, dryrun):
    paths = expand_paths(files)
    cinfo = AniList().search(series_id).to_cinfo()

    for path in paths:
        with CBZFile(path) as cfile:
            if cfile.volume:
                cinfo['Volume'] = cfile.volume

            diff = cfile.info.compare(cinfo, excluding=['Notes'])

            if not diff:
                logger.info(f'{path}: no changes required')
                continue

            if dryrun:
                for item in diff:
                    print(item)
            else:
                cfile.update_cinfo(cinfo)

def parse_args(argv=sys.argv):
    parser = argparse.ArgumentParser(prog=PROG_NAME)
    parser.add_argument('files', nargs='*', type=pathlib.Path)
    parser.add_argument('--anilist', dest='series_id', type=int)
    parser.add_argument('--dryrun', action='store_true')
    args = parser.parse_args(argv[1:])

    return vars(args)

def main():
    logging.basicConfig(format='%(asctime)s - %(name)s - %(levelname)s - %(message)s', level=logging.INFO)

    args = parse_args()

    try:
        cbtag(**args)
    except KeyboardInterrupt:
        return 1

    return 0

if __name__ == '__main__':
    sys.exit(main())
