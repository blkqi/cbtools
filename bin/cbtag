#!/usr/bin/env python

import sys
import pathlib
import argparse
import logging

from cbtools.core import CBZFile, ComicInfo, expand_paths
from cbtools.tag import AniList

logger = logging.getLogger('cbtag')

def cbtag(files, series_id, dryrun):
    files = expand_paths(files)
    cinfo = AniList().search(series_id).to_cinfo()

    for path in files:
        with CBZFile(path) as cfile:
            if cfile.volume:
                cinfo['Volume'] = cfile.volume

            diff = cfile.info.compare(cinfo, excluding=['Notes'])

            if not diff:
                logger.info(f'{path}: no changes required')
                continue

            if dryrun:
                for item in diff:
                    print(item)
            else:
                cfile.update_cinfo(cinfo)

def main():
    logging.basicConfig(format='%(asctime)s - %(name)s - %(levelname)s - %(message)s', level=logging.INFO)

    parser = argparse.ArgumentParser(prog='cbtag')
    parser.add_argument('files', nargs='*', type=pathlib.Path)
    parser.add_argument('--anilist', dest='series_id', type=int, required=True)
    parser.add_argument('--dryrun', action='store_true')
    args = parser.parse_args()

    try:
        cbtag(**vars(args))
    except KeyboardInterrupt:
        return 1

    return 0

if __name__ == '__main__':
    sys.exit(main())
