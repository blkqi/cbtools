#!/usr/bin/env python

import logging

from cbtools import enable_file_logging
from cbtools.config import config
from cbtools.manager import cbmanager

PROG_NAME = 'cbmanager'
enable_file_logging(PROG_NAME)

if __name__ == "__main__":
    if config["manager.test_mode"]:
        logger.info('Running in test mode')

    cbmanager()
