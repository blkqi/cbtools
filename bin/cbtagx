import sys
import pathlib
import argparse
import queue
import time

from cbtools import AniList, CBZFile, ComicInfo

def cbtag(folder, series_id, dryrun):
    cinfo = AniList().search(series_id).to_cinfo()

    for path in folder.iterdir():
        if not path.is_file() or path.suffix != '.cbz':
            continue

        with CBZFile(path) as cfile:
            if cfile.volume:
                cinfo['Volume'] = cfile.volume

            diff = cfile.info.compare(cinfo)

            if not diff:
                print(f'{path}: no changes required')
                continue

            if dryrun:
                for item in diff:
                    print(item)
            else:
                cfile.update_cinfo(cinfo)

def cbtagx(library, dryrun):
    tag_queue = queue.Queue()

    for folder in library.iterdir():
        if not folder.is_dir():
            continue

        tag_queue.put(folder)

    while not tag_queue.empty():
        folder = tag_queue.get()
        dotanilist_file = folder / '.anilist.txt'

        if not dotanilist_file.exists():
            print(f'{folder}: missing .anilist.txt')
            continue

        with open(dotanilist_file, 'r') as f:
            series_id = f.read().strip()
            print(f'{folder}: series_id={series_id}')
            cbtag(folder, series_id, dryrun)

        # AniList currently permits 30 requests per minute
        time.sleep(2)

def main():
    parser = argparse.ArgumentParser(prog='cbtag')
    parser.add_argument('library', type=pathlib.Path)
    parser.add_argument('--dryrun', action='store_true')
    args = parser.parse_args()

    try:
        cbtagx(**vars(args))
    except KeyboardInterrupt:
        return 1

    return 0

if __name__ == '__main__':
    sys.exit(main())
