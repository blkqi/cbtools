#!/usr/bin/env python

import os
import sys
import json
import string
import shutil
import zipfile
import pathlib
import argparse
import lxml.etree

ARG_PATTERN_DEFAULT = '${Series}/${Series} ${Volume}'

class ComicInfo(dict):
    XSD_FILENAME = 'ComicInfo.xsd'
    XML_FILENAME = 'ComicInfo.xml'

    def __init__(self, *args, **kwds):
        super(ComicInfo, self).__init__(*args, **kwds)

    def parse(f, validate=False):
        xml_tree = lxml.etree.parse(f)

        # TODO allow injecting default values into validated documents
        if validate:
            ComicInfo.validate(xml_tree)

        return ComicInfo((child.tag, child.text) for child in xml_tree.getroot())

    def validate(xml_tree):
        xsd_tree = lxml.etree.parse(ComicInfo.XSD_FILENAME)
        schema = lxml.etree.XMLSchema(xsd_tree)
        schema.assertValid(xml_tree)

class CBZFile(object):
    def __init__(self, file, validate=False):
        with zipfile.ZipFile(file, 'r') as z:
            try:
                with z.open(ComicInfo.XML_FILENAME) as c:
                    self._info = ComicInfo.parse(c, validate=validate)
            except KeyError:
                self._info = {}

    def info(self):
        return self._info

class CBZRenamer(object):
    FILENAME_SUFFIX = '.cbz'

    def __init__(self, pattern, default=''):
        self._template = string.Template(pattern)
        self._defaults = {key: default for key in self._template.get_identifiers()}

    def _substitute(self, cbzfile):
        return self._template.substitute(self._defaults, **cbzfile.info()).strip()

    def fullpath(self, cbzfile, root=''):
        path = pathlib.Path(self._substitute(cbzfile))
        return (root / path).with_suffix(self.FILENAME_SUFFIX)

def renamepath(src, dst):
    # create required directory structure
    dst.parent.mkdir(parents=True, exist_ok=True)

    try:
        src.rename(dst)
    except OSError as e:
        if e.errno == 18:
            pass
        else:
            raise
    else:
        return

    # errno 18: target filesystem differs - fallback to copy file
    shutil.copyfile(src, dst)
    src.unlink()

def cbrename(files, pattern, root, validate, dryrun):
    renamer = CBZRenamer(pattern)
    inpaths = (pathlib.Path(f) for f in files)

    for srcpath in inpaths:
        cbzfile = CBZFile(srcpath, validate=validate)
        dstpath = renamer.fullpath(cbzfile, root=root)

        if dryrun:
            print(f'(dryrun) {srcpath} -> {dstpath}')
            #print(json.dumps(cbzfile.info(), indent=2))
        else:
            renamepath(srcpath, dstpath)

def main():
    parser = argparse.ArgumentParser(prog='cbrename')
    parser.add_argument('files', nargs='+')
    parser.add_argument('--root', default='')
    parser.add_argument('--pattern', default=ARG_PATTERN_DEFAULT)
    parser.add_argument('--validate', action='store_true')
    parser.add_argument('--dryrun', action='store_true')
    args = parser.parse_args()

    try:
        cbrename(**vars(args))
    except KeyboardInterrupt:
        return 1

    return 0

if __name__ == '__main__':
    sys.exit(main())
