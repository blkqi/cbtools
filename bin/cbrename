#!/usr/bin/env python

import os
import sys
import json
import string
import zipfile
import pathlib
import argparse
import lxml.etree

ARG_PATTERN_DEFAULT = '${Series}/${Series} ${Volume}'

class ComicInfo(dict):
    def __init__(self, *args, **kwds):
        super(ComicInfo, self).__init__(*args, **kwds)

    def from_file(f):
        tree = lxml.etree.parse(f)
        items = {child.tag: child.text for child in tree.getroot()}
        return ComicInfo(items)

class CBZFile(object):
    COMICINFO_FILENAME = 'ComicInfo.xml'

    def __init__(self, file):
        with zipfile.ZipFile(file, 'r') as z:
            try:
                with z.open(self.COMICINFO_FILENAME) as c:
                    self._info = ComicInfo.from_file(c)
            except KeyError:
                self._info = {}

    def info(self):
        return self._info

class CBZRenamer(object):
    def __init__(self, filename, pattern, root=''):
        self._cbzfile = CBZFile(filename)
        self._template = string.Template(pattern)
        self._root = root

    def path(self):
        info = self._cbzfile.info()
        path = self._template.safe_substitute(**info)
        return self._root / pathlib.PurePath(path).with_suffix('.cbz')

def renamepath(oldpath, newpath):
    newpath.mkdir(parents=True, exist_ok=True)
    os.rename(path, newpath)

def cbzrename(file, root, pattern, dryrun):
    for path in file:
        renamer = CBZRenamer(path, pattern, root)
        newpath = renamer.path()

        if dryrun:
            print(f'(dryrun) {path} -> {newpath}')
            #print(json.dumps(CBZFile(path).info(), indent=2))
        else:
            renamepath(path, newpath)

def main():
    parser = argparse.ArgumentParser(prog='cbrename')
    parser.add_argument('file', nargs='+')
    parser.add_argument('--root', default='')
    parser.add_argument('--pattern', default=ARG_PATTERN_DEFAULT)
    parser.add_argument('--dryrun', action='store_true')
    args = parser.parse_args()

    try:
        cbzrename(**vars(args))
    except KeyboardInterrupt:
        return 1
    return 0

if __name__ == '__main__':
    sys.exit(main())
