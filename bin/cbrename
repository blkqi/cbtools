#!/usr/bin/env python

import os
import sys
import string
import shutil
import pathlib
import argparse

from cbtools import CBZFile

ARG_PATTERN_DEFAULT = '${Series} (${Year})/${Series} ${Volume}'

class CBZRenamer(object):
    FILENAME_SUFFIX = '.cbz'

    def __init__(self, pattern, default=''):
        self._template = string.Template(pattern)
        self._defaults = {key: default for key in self._template.get_identifiers()}

    def _substitute(self, cbzfile):
        info = cbzfile.info
        formatters = {'Series': lambda x: f'{x}',
                      'Volume': lambda x: f'V{int(x):02}',
                      'Writer': lambda x: f'{x}',
                      'Year':   lambda x: f'{x}'}
        inputs = {key: fun(info.get(key)) for key, fun in formatters.items() if key in info}
        return self._template.substitute(self._defaults, **inputs).strip()

    def fullpath(self, cbzfile, root=pathlib.Path('')):
        path = pathlib.Path(self._substitute(cbzfile))
        return (root / path).with_suffix(self.FILENAME_SUFFIX)

def renamepath(src, dst):
    # create required directory structure
    dst.parent.mkdir(parents=True, exist_ok=True)

    try:
        src.rename(dst)
    except OSError as e:
        if e.errno == 18:
            pass
        else:
            raise
    else:
        return

    # errno 18: target filesystem differs - fallback to copy file
    shutil.copyfile(src, dst)
    src.unlink()

def cbrename(files, pattern, root, validate, dryrun):
    renamer = CBZRenamer(pattern)

    for srcpath in files:
        with CBZFile(srcpath) as cbzfile:
            dstpath = renamer.fullpath(cbzfile, root=root)

        if srcpath == dstpath:
            continue
        elif dryrun:
            print(f'(dryrun) "{srcpath}" -> "{dstpath}"')
        else:
            renamepath(srcpath, dstpath)

def main():
    parser = argparse.ArgumentParser(prog='cbrename')
    parser.add_argument('files', nargs='+', type=pathlib.Path)
    parser.add_argument('--root', default='', type=pathlib.Path)
    parser.add_argument('--pattern', default=ARG_PATTERN_DEFAULT)
    parser.add_argument('--validate', action='store_true')
    parser.add_argument('--dryrun', action='store_true')
    args = parser.parse_args()

    try:
        cbrename(**vars(args))
    except KeyboardInterrupt:
        return 1

    return 0

if __name__ == '__main__':
    sys.exit(main())
