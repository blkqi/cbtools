#!/usr/bin/env python

import os
import sys
import json
import string
import zipfile
import pathlib
import argparse
import lxml.etree

ARG_PATTERN_DEFAULT = '${Series}/${Series} ${Volume}'

class ComicInfo(dict):
    XML_SCHEMA_FILENAME = 'ComicInfo.xsd'

    def __init__(self, *args, **kwds):
        super(ComicInfo, self).__init__(*args, **kwds)

    def parse(f):
        xml_tree = lxml.etree.parse(f)
        xsd_tree = lxml.etree.parse(ComicInfo.XML_SCHEMA_FILENAME)

        schema = lxml.etree.XMLSchema(xsd_tree)
        schema.validate(xml_tree)

        return ComicInfo((child.tag, child.text) for child in xml_tree.getroot())

class CBZFile(object):
    COMICINFO_FILENAME = 'ComicInfo.xml'

    def __init__(self, file):
        with zipfile.ZipFile(file, 'r') as z:
            try:
                with z.open(self.COMICINFO_FILENAME) as c:
                    self._info = ComicInfo.parse(c)
            except KeyError:
                self._info = {}

    def info(self):
        return self._info

class CBZRenamer(object):
    FILENAME_SUFFIX = '.cbz'

    def __init__(self, filename, pattern):
        self._cbzfile = CBZFile(filename)
        self._template = string.Template(pattern)

    def _substitute(self):
        defaults = {key: '' for key in self._template.get_identifiers()}
        return self._template.substitute(defaults, **self._cbzfile.info()).strip()

    def fullpath(self, root=''):
        path = pathlib.PurePath(self._substitute())
        return (root / path).with_suffix(self.FILENAME_SUFFIX)

def renamepath(oldpath, newpath):
    newpath.mkdir(parents=True, exist_ok=True)
    os.rename(path, newpath)

def cbzrename(file, root, pattern, dryrun):
    for path in file:
        renamer = CBZRenamer(path, pattern)
        newpath = renamer.fullpath(root)

        if dryrun:
            print(f'(dryrun) {path} -> {newpath}')
            #print(json.dumps(CBZFile(path).info(), indent=2))
        else:
            renamepath(path, newpath)

def main():
    parser = argparse.ArgumentParser(prog='cbrename')
    parser.add_argument('file', nargs='+')
    parser.add_argument('--root', default='')
    parser.add_argument('--pattern', default=ARG_PATTERN_DEFAULT)
    parser.add_argument('--dryrun', action='store_true')
    args = parser.parse_args()

    try:
        cbzrename(**vars(args))
    except KeyboardInterrupt:
        return 1
    return 0

if __name__ == '__main__':
    sys.exit(main())
