#!/usr/bin/env python

import os
import sys
import json
import pathlib
import argparse

from cbtools import CBZFile

def cbinfo(files):
    inpaths = (pathlib.Path(f) for f in files)

    for srcpath in inpaths:
        with CBZFile(srcpath) as cbzfile:
            info = cbzfile.info()

        print(json.dumps(info, indent=2))

def main():
    parser = argparse.ArgumentParser(prog='cbinfo')
    parser.add_argument('files', nargs='+')
    args = parser.parse_args()

    try:
        cbinfo(**vars(args))
    except KeyboardInterrupt:
        return 1

    return 0

if __name__ == '__main__':
    sys.exit(main())
