#!/usr/bin/env python

import os
import sys
import json
import pathlib
import argparse

from cbtools import CBZFile, expand_paths

def cbinfo(files):
    files = expand_paths(files)

    for path in files:
        with CBZFile(path) as cfile:
            print(json.dumps(cfile.info, indent=2))

def main():
    parser = argparse.ArgumentParser(prog='cbinfo')
    parser.add_argument('files', nargs='+', type=pathlib.Path)
    args = parser.parse_args()

    try:
        cbinfo(**vars(args))
    except KeyboardInterrupt:
        return 1

    return 0

if __name__ == '__main__':
    sys.exit(main())
