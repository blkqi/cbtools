#!/usr/bin/env python

import sys
import pathlib
import argparse

from cbtools.log import configure_logging
from cbtools.core import expand_paths
from cbtools.convert import convert


_program_name = 'cbconvert'
_logger = configure_logging()


def cbconvert(files, root, **kwds):
    paths = expand_paths(files)
    for path in paths:
        convert(path, output=root, **kwds)


def parse_args(argv=sys.argv):
    parser = argparse.ArgumentParser(prog=_program_name)
    parser.add_argument('files', nargs='+', type=pathlib.Path)
    parser.add_argument('--path', dest='root', type=str)
    parser.add_argument('--profile', default='KS')
    args = parser.parse_args(argv[1:])

    return vars(args)


def main():
    args = parse_args()

    try:
        cbconvert(**args)
    except KeyboardInterrupt:
        return 1

    return 0


if __name__ == '__main__':
    sys.exit(main())
