#!/usr/bin/env python

import sys
import pathlib
import argparse

from cbtools import configure_logging
from cbtools.convert import convert


_program_name = 'cbconvert'
_logger = configure_logging()


def parse_args(argv=sys.argv):
    parser = argparse.ArgumentParser(prog=_program_name)
    parser.add_argument('files', nargs='+', type=pathlib.Path)
    parser.add_argument('--path', dest='root', type=pathlib.Path)
    parser.add_argument('--profile', default='Kindle Scribe')
    args = parser.parse_args(argv[1:])
    return vars(args)


def main():
    args = parse_args()

    try:
        convert(**args)
    except KeyboardInterrupt:
        return 1

    return 0


if __name__ == '__main__':
    sys.exit(main())
