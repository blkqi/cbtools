#!/usr/bin/env python

import os
import sys
import shutil
import pathlib
import argparse
import tempfile
import subprocess
import logging

from cbtools.core import CBZFile, ComicInfo, expand_paths

logger = logging.getLogger('cbscale')

WAIFU2X_BIN = os.getenv('WAIFU2X_BIN', '/usr/bin/waifu2x-ncnn-vulkan')
WAIFU2X_MODEL = os.getenv('WAIFU2X_MODEL', '/usr/share/waifu2x-ncnn-vulkan/models-upconv_7_anime_style_art_rgb')
OUTFILE_SUFFIX = 'cbscale'

def upscale(cfile, scale, noise, ftype, gpuid,
            entrypoint=WAIFU2X_BIN, model=WAIFU2X_MODEL):

    with tempfile.TemporaryDirectory() as srcdir, \
            tempfile.TemporaryDirectory() as dstdir:

        cfile.extractall(path=srcdir, flatten=True)

        try:
            process = subprocess.Popen(
                [
                    entrypoint,
                    '-i', srcdir,
                    '-o', dstdir,
                    '-s', str(scale),
                    '-n', str(noise),
                    '-f', ftype,
                    '-g', gpuid,
                    '-m', model,
                ],
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT
            )
        except FileNotFoundError:
            raise RuntimeError(f'waifu2x-ncnn-vulkan not found at {entrypoint}')

        stdout, _ = process.communicate()

        if process.returncode != 0:
            sys.stderr.write(stdout.decode())
            raise RuntimeError(f'waifu2x-ncnn-vulkan error code {process.returncode}')

        srcpath = pathlib.Path(srcdir)
        dstpath = pathlib.Path(dstdir)
        outpath = pathlib.Path(cfile.filename)
        outname = f'{outpath.with_suffix('')}_{OUTFILE_SUFFIX}{outpath.suffix}'

        with CBZFile(outname, mode='w') as cfile:
            # add comicinfo
            path = srcpath / ComicInfo.XML_FILENAME
            if path.exists():
                cfile.write(path, arcname=path.name)

            # add images
            for path in sorted(dstpath.iterdir()):
                cfile.write(path, arcname=path.name)

def cbscale(files, **kwds):
    files = expand_paths(files)

    for path in files:
        with CBZFile(path) as cfile:
            upscale(cfile, **kwds)

def main():
    logging.basicConfig(format='%(asctime)s - %(name)s - %(levelname)s - %(message)s')

    parser = argparse.ArgumentParser(prog='cbscale')
    parser.add_argument('files', nargs='+', type=pathlib.Path)
    parser.add_argument('--scale', default=2, choices=[1,2,4,8,16,32])
    parser.add_argument('--noise', default=2, choices=[-1,0,1,2,3])
    parser.add_argument('--ftype', default='jpg', choices=['jpg', 'png', 'webp'], type=str)
    parser.add_argument('--gpuid', default='auto', type=str)
    args = parser.parse_args()

    try:
        cbscale(**vars(args))
    except KeyboardInterrupt:
        return 1

    return 0

if __name__ == '__main__':
    sys.exit(main())
