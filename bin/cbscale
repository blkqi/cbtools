#!/usr/bin/env python

import os
import sys
import shutil
import pathlib
import argparse
import tempfile
import itertools
import subprocess
import logging

from cbtools.log import configure_logging
from cbtools.core import ComicArchive, ComicInfo, expand_paths
from cbtools.constants import COMICINFO_XML_NAME

PROG_NAME = 'cbscale'
logger = configure_logging()

WAIFU2X_BIN = os.getenv('WAIFU2X_BIN', '/usr/bin/waifu2x-ncnn-vulkan')
WAIFU2X_MODEL = os.getenv('WAIFU2X_MODEL', '/usr/share/waifu2x-ncnn-vulkan/models-upconv_7_anime_style_art_rgb')
OUTFILE_SUFFIX = 'cbscale'

def _write_output(outpath, srcpath, dstpath):
    logger.info(f'Packing archive "{outpath}"')

    cfile = ComicArchive(outpath)

    add_paths = sorted(dstpath.iterdir())
    info_path = srcpath / COMICINFO_XML_NAME

    if info_path.exists():
        add_paths = itertools.chain([info_path], add_paths)

    for path in add_paths:
        with open(path, 'rb') as f:
            cfile.add(path.name, f)

    logger.info(f'Created archive "{outpath}"')

def _extract_flatten(cfile, root):
    logger.info(f'Unpacking archive "{cfile.filepath}"')

    for member in cfile.list():
        if member.is_dir():
            continue

        path = root / pathlib.Path(member.name).as_posix().replace('/', '__')

        with open(path, 'wb') as f:
            cfile.extract(member.name, f)

def _upscale_images(srcpath, dstpath, scale, noise, ftype, gpuid,
                 entrypoint=WAIFU2X_BIN, model=WAIFU2X_MODEL):
    logger.info(f'Upscaling image data')

    args = ['-i', srcpath, '-o', dstpath,
            '-s', str(scale), '-n', str(noise),
            '-f', ftype, '-g', gpuid, '-m', model]

    try:
        process = subprocess.run([entrypoint, *args],
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT
        )
    except FileNotFoundError:
        raise RuntimeError(f'waifu2x-ncnn-vulkan not found: {entrypoint}')

    if process.returncode != 0:
        sys.stderr.write(process.stdout.decode())
        raise RuntimeError(f'waifu2x-ncnn-vulkan error code: {process.returncode}')

def _output_filename(cfile, root=None):
    stem = '_'.join((cfile.filepath.stem, OUTFILE_SUFFIX))
    path = root or cfile.filepath.parent
    return (path / (str(stem) + '.cbz'))

def upscale(cfile, path, **kwds):
    with tempfile.TemporaryDirectory() as srcdir, \
            tempfile.TemporaryDirectory() as dstdir:

        srcpath = pathlib.Path(srcdir)
        dstpath = pathlib.Path(dstdir)
        outpath = _output_filename(cfile, root=path)

        if outpath.exists():
            raise RuntimeError(f'path "{outpath}" already exists!')

        _extract_flatten(cfile, srcpath)
        _upscale_images(srcpath, dstpath, **kwds)
        _write_output(outpath, srcpath, dstpath)

def cbscale(files, **kwds):
    files = expand_paths(files)

    for path in files:
        cfile = ComicArchive(path)
        upscale(cfile, **kwds)

def parse_args(argv=sys.argv):
    parser = argparse.ArgumentParser(prog=PROG_NAME)
    parser.add_argument('files', nargs='+', type=pathlib.Path)
    parser.add_argument('--path', type=pathlib.Path)
    parser.add_argument('--scale', default=2, choices=[1,2,4,8,16,32])
    parser.add_argument('--noise', default=2, choices=[-1,0,1,2,3])
    parser.add_argument('--ftype', default='jpg', choices=['jpg', 'png', 'webp'], type=str)
    parser.add_argument('--gpuid', default='auto', type=str)
    args = parser.parse_args(argv[1:])

    return vars(args)

def main():
    args = parse_args()

    try:
        cbscale(**args)
    except KeyboardInterrupt:
        return 1

    return 0

if __name__ == '__main__':
    sys.exit(main())
