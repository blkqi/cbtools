#!/usr/bin/env python

import sys
import argparse
import tempfile
import logging

from pathlib import Path
from cbtools import configure_logging, convert
from cbtools.core import expand_paths


_program_name = 'cbscale'
logger = configure_logging()
convert._output_suffix = _program_name

def cbscale(files, root, **kwds):
    for cbx_path in expand_paths(files):
        with tempfile.TemporaryDirectory() as tmp_dir:

            out_path = convert._output_filename(cbx_path, root=root)

            if out_path.exists():
                logger.error(f'{out_path!s}: already exists')
                return 1

            tmp_path = Path(tmp_dir)
            (src_path := (tmp_path / 'extract')).mkdir()
            (dst_path := (tmp_path / 'upscale')).mkdir()

            convert._extract_all(cbx_path, src_path)
            convert._upscale_images(src_path, dst_path)
            convert._create_archive(out_path, src_path, dst_path)


def parse_args(argv=sys.argv):
    parser = argparse.ArgumentParser(prog=_program_name)
    parser.add_argument('files', nargs='+', type=Path)
    parser.add_argument('--path', dest='root', type=Path)
    args = parser.parse_args(argv[1:])
    return vars(args)


def main():
    args = parse_args()

    try:
        sts = cbscale(**args)
    except KeyboardInterrupt:
        return 1

    return sts

if __name__ == '__main__':
    sys.exit(main())
