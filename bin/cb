#!/usr/bin/env python

import sys
import json
import argparse
import logging

from pathlib import Path

from cbtools import configure_logging
from cbtools.convert import convert
from cbtools.core import ComicArchive, expand_paths
from cbtools.info import info
from cbtools.manager import manager, flush, rescan, clear, list_items
from cbtools.rename import rename
from cbtools.tag import tag


logger = configure_logging()


def parse_args(argv=sys.argv):
    parser = argparse.ArgumentParser('cb')
    parser.add_argument('--debug', action='store_true')
    subparsers = parser.add_subparsers()

    def add_info_parser(subparsers):
        parser = subparsers.add_parser('info')
        parser.add_argument('files', nargs='+', type=Path)
        parser.set_defaults(command=info)

    def add_rename_parser(subparsers):
        parser = subparsers.add_parser('rename')
        parser.add_argument('files', nargs='+', type=Path)
        parser.add_argument('--path', dest='root', type=Path, default=Path(''))
        parser.add_argument('--dryrun', action='store_true')
        parser.set_defaults(command=rename)

    def add_tag_parser(subparsers):
        parser = subparsers.add_parser('tag')
        parser.add_argument('files', nargs='+', type=Path)
        parser.add_argument('--anilist', dest='series_id', type=int)
        parser.add_argument('--dryrun', action='store_true')
        parser.set_defaults(command=tag)

    def add_convert_parser(subparsers):
        parser = subparsers.add_parser('convert')
        parser.add_argument('files', nargs='+', type=Path)
        parser.add_argument('--path', dest='root', type=Path)
        parser.set_defaults(command=convert)

    def add_manager_parser(subparsers):
        parser = subparsers.add_parser('manager')
        subparsers = parser.add_subparsers()

        def add_run_parser(subparsers):
            parser = subparsers.add_parser('run')
            parser.set_defaults(command=lambda **kwds: manager())

        def add_flush_parser(subparsers):
            parser = subparsers.add_parser('flush')
            parser.set_defaults(command=lambda **kwds: flush())

        def add_clear_parser(subparsers):
            parser = subparsers.add_parser('clear')
            parser.set_defaults(command=lambda **kwds: clear())

        def add_rescan_parser(subparsers):
            parser = subparsers.add_parser('rescan')
            parser.add_argument('files', nargs='*', type=Path, default=None)
            parser.set_defaults(command=rescan)

        def add_list_parser(subparsers):
            parser = subparsers.add_parser('list')
            parser.set_defaults(command=lambda **kwds: print(list_items().json()))

        add_run_parser(subparsers)
        add_flush_parser(subparsers)
        add_clear_parser(subparsers)
        add_rescan_parser(subparsers)
        add_list_parser(subparsers)

    add_info_parser(subparsers)
    add_rename_parser(subparsers)
    add_tag_parser(subparsers)
    add_convert_parser(subparsers)
    add_manager_parser(subparsers)

    args = parser.parse_args(argv[1:])

    if hasattr(args, 'debug'):
        if args.debug:
            logger.setLevel(logging.DEBUG)
        delattr(args, 'debug')

    return vars(args)


def main():
    args = parse_args()
    func = args.pop('command')

    try:
        func(**args)
    except KeyboardInterrupt:
        return 1

    return 0


if __name__ == '__main__':
    sys.exit(main())
